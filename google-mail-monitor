const modelId = "gemini-2.5-flash-lite"; 

/**
 * Main function to run weekly. 
 * Configure this to run on a "Time-driven trigger".
 */
function runWeeklyEmailAgent() {
  const GMAIL_FILTERS = [
  "label:school---audrey",
  "label:school---clara",
  "label:school---harriet",
]; 

  const GEMINI_API_KEY = PropertiesService.getScriptProperties().getProperty("GEM_KEY_PROP");
  
  // Loop through each filter in the array
  for (const filter of GMAIL_FILTERS) {
    console.log(`Processing filter: ${filter}`);

    // 1. Fetch relevant threads for the current filter
    const threads = GmailApp.search(filter);
    if (threads.length === 0) {
      console.log(`No new emails found matching the filter: ${filter}`);
      continue; // Skip the rest of the loop and move to the next filter
    }

    // 2. Aggregate email content
    let combinedContent = "";
    threads.forEach(thread => {
      const messages = thread.getMessages();    
      messages.forEach(msg => {
        // Keeping your console.log for debugging, but you might want to remove it later if it gets noisy
        console.log(msg.getPlainBody().slice(0, 20)); 
        combinedContent += `--- New Message ---\nDate: ${msg.getDate()}\nContent: ${msg.getPlainBody()}\n`;
      });
    });

    // 3. Send to AI for extraction (The "Agent" part)
    const report = callGeminiAgent(combinedContent, GEMINI_API_KEY);

    // 4. Notify yourself (dynamically adding the filter name to the subject)
    GmailApp.sendEmail(
      Session.getActiveUser().getEmail(), 
      `📅 Weekly Activity Digest: ${filter}`, 
      report
    );
  }
}

/**
 * Sends text to Gemini to extract structured activity data.
 */
function callGeminiAgent(text, apiKey) {  
  const url = `https://generativelanguage.googleapis.com/v1beta/models/${modelId}:generateContent?key=${apiKey}`;
  
  const prompt = `Analyze the following email content. Identify all specific activities, deadlines, or meetings scheduled for NEXT week. 
                  Provide a clean, bulleted list with dates and a brief summary for each. 
                  Email Content: \n${text}`;

  const payload = {
    contents: [{ parts: [{ text: prompt }] }]
  };

  const options = {
    method: 'post',
    contentType: 'application/json',
    payload: JSON.stringify(payload)
  };

  const response = UrlFetchApp.fetch(url, options);
  const json = JSON.parse(response.getContentText());
  
  return json.candidates[0].content.parts[0].text;
}
